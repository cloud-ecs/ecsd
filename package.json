{
  "name": "ecsd",
  "description": "Email Content Scanning Daemon",
  "version": "0.9.1",
  "keywords": [
    "email",
    "antivirus",
    "spam filter",
    "content filter"
  ],
  "homepage": "https://github.com/cloud-ecs/ecsd",
  "bugs": {
    "url": "https://github.com/cloud-ecs/ecsd/issues"
  },
  "files": [
    "html",
    "lib",
    "routes",
    "server.js",
    "cloud-email-scanner.ini"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-ecs/ecsd.git"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ini": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0"
  },
  "license": "BSD-2-Clause",
  "prettier": {
    "singleQuote": true,
    "semi": false
  },
  "scripts": {
    "lint": "eslint *.js lib routes test",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "start": "node server.js",
    "test": "node --test --test-force-exit",
    "test:coverage": "node --test --experimental-test-coverage --test-force-exit",
    "test:coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-force-exit"
  }
}
